{
  "name": "molibot",
  "version": "2.2.5",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "imports": {
    "#weixin-agent-sdk/*": "./package/weixin-agent-sdk/*",
    "#qqbot/*": "./package/qqbot/*",
    "#acp/*": "./package/acp/src/*"
  },
  "bin": {
    "molibot": "./bin/molibot.js"
  },
  "scripts": {
    "dev": "svelte-kit sync && vite dev --mode production",
    "build": "svelte-kit sync && vite build",
    "desktop:dev": "corepack pnpm --dir apps/desktop run tauri:dev",
    "desktop:prepare": "corepack pnpm --dir apps/desktop run prepare:runtime",
    "desktop:build": "corepack pnpm --dir apps/desktop run tauri:build",
    "desktop:check": "corepack pnpm --dir apps/desktop run check",
    "desktop:test": "corepack pnpm --dir apps/desktop run test",
    "test:desktop-release": "node --test scripts/finalize-desktop-release.test.mjs",
    "start": "node scripts/start-server.mjs",
    "test:service-bootstrap": "node --test scripts/runtime/service-lease.test.mjs && node --import ./scripts/register-loader.js --import tsx --test src/lib/server/app/desktopHandshake.test.ts",
    "test:desktop-chat": "node --import ./scripts/register-loader.js --import tsx --test src/lib/server/app/desktopAgents.test.ts src/lib/server/app/desktopBootstrap.test.ts src/lib/server/app/desktopChannels.test.ts src/lib/server/app/desktopExternalSessions.test.ts src/lib/server/app/desktopHostBash.test.ts src/lib/server/app/desktopMcp.test.ts src/lib/server/app/desktopMediaGenerate.test.ts src/lib/server/app/desktopMediaTasks.test.ts src/lib/server/app/desktopMemory.test.ts src/lib/server/app/desktopModels.test.ts src/lib/server/app/desktopPlugins.test.ts src/lib/server/app/desktopProfiles.test.ts src/lib/server/app/desktopProviders.test.ts src/lib/server/app/desktopProviderSubmit.test.ts src/lib/server/app/desktopRunHistory.test.ts src/lib/server/app/desktopRuntimeEnv.test.ts src/lib/server/app/desktopSandbox.test.ts src/lib/server/app/desktopSkills.test.ts src/lib/server/app/desktopTasks.test.ts src/lib/server/app/desktopTrace.test.ts src/lib/server/app/desktopTtsGenerate.test.ts src/lib/server/app/desktopUsage.test.ts src/lib/server/app/desktopWebSearch.test.ts src/lib/server/sessions/store.test.ts apps/desktop/src/lib/api.test.ts",
    "release": "bin/molibot-release.sh",
    "manage": "node bin/molibot-manage.js",
    "cli": "tsx src/lib/server/app/index.ts --cli",
    "mory:build": "corepack pnpm --dir package/mory run build",
    "mory:test": "corepack pnpm --dir package/mory run test",
    "mory:smoke": "corepack pnpm --dir package/mory run smoke"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.26",
    "@larksuiteoapi/node-sdk": "^1.66.0",
    "@mariozechner/pi-agent-core": "^0.73.1",
    "@mariozechner/pi-ai": "^0.73.1",
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sinclair/typebox": "^0.34.49",
    "clsx": "^2.1.1",
    "diff": "^8.0.2",
    "dotenv": "^16.5.0",
    "grammy": "^1.44.0",
    "marked": "^16.4.2",
    "mpg123-decoder": "^1.0.3",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "silk-wasm": "^3.7.1",
    "svelte": "^5.38.10",
    "tailwind-merge": "^3.5.0",
    "typebox": "^1.1.33",
    "uuid": "^11.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@mariozechner/mini-lit": "^0.2.0",
    "@mariozechner/pi-web-ui": "^0.73.1",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.14.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.48.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/express": "^4.17.21",
    "@types/node": "^24.3.1",
    "@types/ws": "^8.18.1",
    "bits-ui": "^2.18.1",
    "express": "^4.21.2",
    "lit": "^3.3.1",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^7.1.6"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
